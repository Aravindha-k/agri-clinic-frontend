# Agri Admin Panel - Environment Configuration
# Copy to .env.local for local development (gitignored).

# Backend API host — REST clients use /api/v1/ on this host
VITE_API_BASE_URL=http://127.0.0.1:8000

# Production: set in .env.production (see that file)

# Optional: relative proxy mode (Vite dev server proxies /api → VITE_API_BASE_URL)
# VITE_API_BASE_URL=/api/v1/
# VITE_PROXY_TARGET=

# Optional: API Timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# Optional: Admin map tile providers (no API keys required by default)
# VITE_MAP_STANDARD_TILE_URL=https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png
# VITE_MAP_SATELLITE_TILE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}
# VITE_MAP_LABELS_TILE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}
# VITE_MAP_FALLBACK_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
