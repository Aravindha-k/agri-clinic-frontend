# Agri Admin Panel - Environment Configuration

# API Base URL (Backend)
# Local dev: use Vite proxy (recommended) — copy to .env
VITE_API_BASE_URL=/api/v1/

# Production (Render): set in dashboard OR use .env.production (committed)
# VITE_API_BASE_URL=https://agri-clinic-backend.onrender.com/api/v1/

# Optional: API Timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# Vite dev proxy target (Django must be running here in local dev)
# VITE_PROXY_TARGET=http://127.0.0.1:8000
