          "name": "Bulk Location Upload",
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"},{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "[\n  {\"latitude\": 11.6643, \"longitude\": 78.1460, \"timestamp\": \"2025-01-15T09:00:00Z\"},\n  {\"latitude\": 11.6650, \"longitude\": 78.1470, \"timestamp\": \"2025-01-15T09:05:00Z\"}\n]"},
            "url": {"raw": "{{base_url}}/tracking/location/bulk/","host": ["{{base_url}}"],"path": ["tracking","location","bulk",""]}
          }
        },
