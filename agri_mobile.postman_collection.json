          "name": "Mobile Tracking Ping",
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"},{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"latitude\": 11.6643,\n  \"longitude\": 78.1460\n}"},
            "url": {"raw": "{{base_url}}/mobile/tracking/","host": ["{{base_url}}"],"path": ["mobile","tracking",""]}
          }
        },
        {
          "name": "Start WorkDay",
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"},{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"latitude\": 11.6643,\n  \"longitude\": 78.1460\n}"},
            "url": {"raw": "{{base_url}}/tracking/workday/start/","host": ["{{base_url}}"],"path": ["tracking","workday","start",""]}
          }
        },
        {
          "name": "End WorkDay",
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"},{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"latitude\": 11.6643,\n  \"longitude\": 78.1460\n}"},
            "url": {"raw": "{{base_url}}/tracking/workday/end/","host": ["{{base_url}}"],"path": ["tracking","workday","end",""]}
          }
        }
      ]
    },
    {
      "name": "Visits",
      "item": [
        {
          "name": "List My Visits",
          "event": [{"listen": "test","script": {"exec": ["var res = pm.response.json();","pm.test('Response OK', function () { pm.expect(pm.response.code).to.eql(200); });","if (res.data && res.data.results && res.data.results.length > 0) { pm.environment.set('visit_id', res.data.results[0].id); }"],"type": "text/javascript"}}],
          "request": {
            "method": "GET","header": [{"key": "Authorization","value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/mobile/visits/","host": ["{{base_url}}"],"path": ["mobile","visits",""]}
          }
        },
        {
          "name": "Start Visit",
          "event": [{"listen": "test","script": {"exec": ["var res = pm.response.json();","pm.test('Visit created', function () { pm.expect(pm.response.code).to.eql(201); });","if (res.visit_id) { pm.environment.set('visit_id', res.visit_id); }","else if (res.data && res.data.id) { pm.environment.set('visit_id', res.data.id); }"],"type": "text/javascript"}}],
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"},{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"crop\": {{crop_id}},\n  \"latitude\": 11.6643,\n  \"longitude\": 78.1460,\n  \"farmer_name\": \"Ravi Kumar\",\n  \"village\": {{village_id}}\n}"},
            "url": {"raw": "{{base_url}}/visits/start/","host": ["{{base_url}}"],"path": ["visits","start",""]}
          }
        },
        {
          "name": "Complete Visit",
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"},{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"notes\": \"Completed field inspection.\"\n}"},
            "url": {"raw": "{{base_url}}/visits/{{visit_id}}/complete/","host": ["{{base_url}}"],"path": ["visits","{{visit_id}}","complete",""]}
          }
        },
        {
          "name": "Upload Visit Media",
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"}],
            "body": {"mode": "formdata","formdata": [{"key": "file","type": "file","src": ""},{"key": "media_type","value": "image","type": "text"},{"key": "caption","value": "Crop photo","type": "text"}]},
            "url": {"raw": "{{base_url}}/visits/{{visit_id}}/upload-media/","host": ["{{base_url}}"],"path": ["visits","{{visit_id}}","upload-media",""]}
          }
        },
        {
          "name": "Visit Stats",
          "request": {
            "method": "GET","header": [{"key": "Authorization","value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/mobile/visits/stats/","host": ["{{base_url}}"],"path": ["mobile","visits","stats",""]}
          }
        },
        {
          "name": "Active Visit",
          "request": {
            "method": "GET","header": [{"key": "Authorization","value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/visits/active/","host": ["{{base_url}}"],"path": ["visits","active",""]}
          }
        }
      ]
    },
