{
  "info": {
    "_postman_id": "agri-mobile-v2",
    "name": "Agri Clinic — Mobile API",
    "description": "Mobile collection for field officers. Base URL: {{base_url}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Mobile Login",
          "event": [{"listen": "test","script": {"exec": ["var res = pm.response.json();","pm.test('Login success — access token returned', function () { pm.expect(res.access).to.exist; });","if (res.access) { pm.environment.set('access_token', res.access); pm.environment.set('refresh_token', res.refresh); }"],"type": "text/javascript"}}],
          "request": {
            "method": "POST","header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"employee_id\": \"EMP001\",\n  \"password\": \"pass1234\"\n}"},
            "url": {"raw": "{{base_url}}/mobile/auth/login/","host": ["{{base_url}}"],"path": ["mobile","auth","login",""]}
          }
        },
        {
          "name": "Refresh Token",
          "event": [{"listen": "test","script": {"exec": ["var res = pm.response.json();","if (res.access) { pm.environment.set('access_token', res.access); }"],"type": "text/javascript"}}],
          "request": {
            "method": "POST","header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"},
            "url": {"raw": "{{base_url}}/mobile/auth/refresh/","host": ["{{base_url}}"],"path": ["mobile","auth","refresh",""]}
          }
        },
        {
          "name": "My Profile (me)",
          "event": [{"listen": "test","script": {"exec": ["pm.test('Profile returned', function () { pm.expect(pm.response.code).to.eql(200); });"],"type": "text/javascript"}}],
          "request": {
            "method": "GET","header": [{"key": "Authorization","value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/mobile/auth/me/","host": ["{{base_url}}"],"path": ["mobile","auth","me",""]}
          }
        }
      ]
    },
    {
      "name": "Work Log",
      "item": [
        {
          "name": "Start Work",
          "event": [{"listen": "test","script": {"exec": ["pm.test('Work started', function () { pm.expect(pm.response.json().success).to.eql(true); });"],"type": "text/javascript"}}],
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"},{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"latitude\": 11.6643,\n  \"longitude\": 78.1460\n}"},
            "url": {"raw": "{{base_url}}/mobile/work/start/","host": ["{{base_url}}"],"path": ["mobile","work","start",""]}
          }
        },
        {
          "name": "Stop Work",
          "request": {
            "method": "POST","header": [{"key": "Authorization","value": "Bearer {{access_token}}"},{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"latitude\": 11.6643,\n  \"longitude\": 78.1460\n}"},
            "url": {"raw": "{{base_url}}/mobile/work/stop/","host": ["{{base_url}}"],"path": ["mobile","work","stop",""]}
          }
        },
        {
          "name": "Work Status",
          "request": {
            "method": "GET","header": [{"key": "Authorization","value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/mobile/work/status/","host": ["{{base_url}}"],"path": ["mobile","work","status",""]}
          }
        }
      ]
    },
    {
